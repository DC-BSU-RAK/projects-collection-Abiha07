<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/modal_bg"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧠"
            android:textSize="56sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How to use Mood Calculator"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"
            android:gravity="center" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#44FFFFFF"
            android:layout_marginVertical="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome to the Mood Calculator — a calculator that processes emotions, not numbers!\n\n📌 Step 1\nTap any mood button from the grid. This is your FIRST mood.\n\n📌 Step 2\nTap an operation button (Plus, Minus, Times, Divided by) to choose how your moods interact.\n\n📌 Step 3\nTap a second mood button. The app will instantly blend your two moods into a unique emotional result!\n\n🔁 To try again, tap CLEAR and start over.\n\n💡 Tip: The same moods may produce different blends depending on the operation you choose. Explore them all!"
            android:textSize="15sp"
            android:textColor="#DDFFFFFF"
            android:lineSpacingExtra="4dp" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Got it!"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/accent_purple"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="32dp" />

    </LinearLayout>
</ScrollView>
