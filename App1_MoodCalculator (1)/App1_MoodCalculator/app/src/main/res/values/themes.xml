<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MoodCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <style name="Theme.MoodCalculator.Splash" parent="Theme.MoodCalculator">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.MoodCalculator.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="android:windowBackground">@color/modal_bg</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="MoodButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">@color/mood_btn_color</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="OpButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:layout_margin">2dp</item>
    </style>

</resources>
